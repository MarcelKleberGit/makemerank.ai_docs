{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MakeMeRank.ai",
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo.png",
    "href": "https://makemerank.ai"
  },
  "colors": {
    "primary": "#EA580C",
    "light": "#F7931A",
    "dark": "#EA580C"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book",
          "href": "/"
        },
        {
          "anchor": "App",
          "icon": "rocket",
          "href": "https://makemerank.ai"
        },
        {
          "anchor": "GEO Wiki",
          "icon": "book-open-cover",
          "href": "https://makemerank.ai/wiki"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Quick Scan",
            "pages": [
              "guides/quickscan",
              "guides/interpreting-scores",
              "guides/how-quickscan-works"
            ]
          },
          {
            "group": "Full Report",
            "pages": ["guides/full-report", "guides/how-analysis-works", "guides/actions"]
          },
          {
            "group": "Content Generation",
            "pages": [
              "guides/content-generation",
              "guides/post-image",
              "guides/linkedin-integration",
              "guides/writing-styles"
            ]
          },
          {
            "group": "GEO basics",
            "pages": ["guides/geo-overview", "guides/methodology"]
          },
          {
            "group": "Account",
            "pages": ["guides/plans", "guides/faq"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Login",
        "href": "https://makemerank.ai/auth"
      },
      {
        "label": "Support",
        "href": "mailto:support@makemerank.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Scan for free now",
      "href": "https://makemerank.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/makemerankai",
      "linkedin": "https://www.linkedin.com/company/makemerank-ai/"
    }
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "feedback": {
    "suggestEdit": false,
    "raiseIssue": false
  }
}
